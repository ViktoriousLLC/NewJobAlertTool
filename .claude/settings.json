{
  "enabledPlugins": {
    "postgres-best-practices@supabase-agent-skills": true
  },
  "permissions": {
    "allow": [
      "mcp__supabase__list_projects",
      "mcp__linear-server__list_issues",
      "mcp__linear-server__get_issue"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Read",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/sidecar-guard.js\"" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-merge-guard.js\"" }
        ]
      }
    ]
  }
}
