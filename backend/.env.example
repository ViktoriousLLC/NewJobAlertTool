# NewJobAlertTool backend — environment variables
#
# Copy to .env for local dev (use PLACEHOLDER values locally; real keys live on
# Railway only). This file documents every variable the backend code reads, so a
# required var can never again go unset-and-unnoticed in production.
#
# History: SENTRY_DSN was added in code on 2026-02-11 but never set on Railway
# and never documented here. Backend error reporting was silently dead for 3.5
# months because Sentry.init() no-ops without a DSN (DEV-27). This file + the
# boot/daily liveness probe in src/lib/sentryHealth.ts exist so that can't recur.

# --- Core ---
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# --- Supabase (auth + database) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=             # public anon key (fallback JWT verification)
SUPABASE_SERVICE_KEY=          # service-role key (server-side DB writes) — SECRET
SUPABASE_JWT_SECRET=           # legacy; no longer used since the 2026-05-28 JWKS migration (kept for rollback)

# --- Email (Resend) ---
RESEND_API_KEY=                # SECRET. Without it, all email sends (incl. the Sentry-down alarm) silently no-op.
ADMIN_EMAIL=vikrant.agar@gmail.com   # recipient for admin digest + ops alerts. Defaults in code if unset.
ALERT_RECIPIENT_EMAIL=         # legacy alert recipient

# --- Observability (REQUIRED in production) ---
# SENTRY_DSN must be the FULL Default DSN of the Sentry project. A missing OR
# truncated value is dropped silently by the SDK. Verified at boot + daily by
# src/lib/sentryHealth.ts, which emails admin if ingestion is broken.
SENTRY_DSN=https://<publicKey>@<org>.ingest.us.sentry.io/<projectId>
# Backend PostHog capture (capturePosthogEvent). Without one of these, all
# server-side product analytics + the observability.* health events no-op.
POSTHOG_API_KEY=               # PostHog project API key (publishable)
POSTHOG_HOST=https://us.i.posthog.com

# --- Cron ---
CRON_SECRET=                   # SECRET. Bearer token guarding /api/cron/* endpoints.

# --- AI / interview feature ---
ANTHROPIC_API_KEY=             # SECRET
OPENAI_API_KEY=                # SECRET
GEMINI_API_KEY=                # SECRET
HUME_API_KEY=                  # SECRET
ELEVENLABS_API_KEY=            # SECRET
ELEVENLABS_AGENT_ID=

# --- Integrations ---
LINEAR_API_KEY=                # SECRET. Powers feedback -> Linear issue creation.

# NOTE: RAILWAY_* variables (RAILWAY_SERVICE_NAME, RAILWAY_PROJECT_ID, etc.) are
# auto-injected by Railway at runtime. Do not set them manually.
